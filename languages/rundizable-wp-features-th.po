msgstr "โพสต์ (ด้านหน้า)"

#. translators: %1$s The Front-end setting name.
#: App/config/settings_rdawpf.php:124
#, php-format
msgid ""
"Enable or disable media for front-end. Disabled media will be redirect to home page. If %1$s is "
